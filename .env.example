# ─── General ────────────────────────────────────────────────
ENV=development
SECRET_KEY=change-me-in-production-use-a-long-random-string
API_V1_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Database (PostgreSQL) ──────────────────────────────────
POSTGRES_USER=russpeak
POSTGRES_PASSWORD=russpeak
POSTGRES_DB=russpeak
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg2://russpeak:russpeak@db:5432/russpeak

# ─── Redis (Celery broker + cache) ──────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ─── Object storage (S3-compatible; MinIO in dev) ───────────
S3_ENDPOINT_URL=http://minio:9000
S3_PUBLIC_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=russpeak-media
S3_REGION=us-east-1

# ─── AI: Speech-to-text ─────────────────────────────────────
# Provider: "auto" uses Azure when AZURE_SPEECH_KEY is set, otherwise falls back
# to OpenAI Whisper. Force with "azure" or "whisper".
STT_PROVIDER=auto
STT_LANGUAGE=ru-RU

# Azure Speech (PREFERRED — faithful transcript + pronunciation scoring).
# Create a Speech resource: https://portal.azure.com → "Speech service",
# copy KEY 1 and the Region.
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=eastus

# OpenAI Whisper (FALLBACK — transcription only, no pronunciation scoring).
# Used automatically when AZURE_SPEECH_KEY is empty. Get a key: https://platform.openai.com
OPENAI_API_KEY=
WHISPER_MODEL=whisper-1
# OpenAI is ALSO the grader BACKUP: when Gemini fails (e.g. free-tier quota),
# grading/feedback falls back to OpenAI using OPENAI_API_KEY above.
OPENAI_GRADER_MODEL=gpt-4o-mini

# ─── AI: Google Gemini (text analysis) ──────────────────────
# Bepul kalit: https://aistudio.google.com/apikey
# Bepul kunlik limit (RPD) modelga qarab farq qiladi (https://aistudio.google.com/rate-limit).
# gemini-3.1-flash-lite — bepul tarifda ~500 so'rov/kun (2.5-flash/2.5-flash-lite atigi ~20/kun).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite

# ─── Auth ───────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Google Sign-In (optional) ──────────────────────────────
# Create an OAuth 2.0 Web Client ID at https://console.cloud.google.com/apis/credentials
# Add http://localhost:5173 to "Authorized JavaScript origins".
# Used by BOTH backend (token verification) and frontend (button). Leave empty to disable.
GOOGLE_CLIENT_ID=

# ─── Email (SMTP) — sign-up verification codes ──────────────
# Provider-agnostic. Leave SMTP_HOST/SMTP_USER empty to disable real sending —
# the code is then printed to the backend logs (fine for local development).
#
# Gmail: enable 2-Step Verification, then create an App Password
#   (https://myaccount.google.com/apppasswords) and use it as SMTP_PASSWORD.
#   Free Gmail allows ~500 emails/day — plenty for ~50 sign-ups/day.
#   For better deliverability later, swap these for Resend/Mailgun/SendGrid SMTP.
SMTP_HOST=                        # e.g. smtp.gmail.com
SMTP_PORT=587
SMTP_USER=                        # e.g. you@gmail.com
SMTP_PASSWORD=                    # Gmail App Password (NOT your normal password)
SMTP_FROM=                        # defaults to SMTP_USER when empty
SMTP_FROM_NAME=Govori
SMTP_STARTTLS=true                # true for port 587; false uses SSL on port 465
# Verification code behaviour
EMAIL_OTP_LENGTH=6
EMAIL_OTP_TTL_SEC=600             # code lifetime in seconds (10 min)
EMAIL_OTP_MAX_ATTEMPTS=5          # wrong tries before the code is burned

# ─── Freemium ───────────────────────────────────────────────
# Free speaking attempts a student gets before premium is required.
FREE_ATTEMPT_LIMIT=10

# ─── Ops / observability ────────────────────────────────────
LOG_LEVEL=INFO
LOG_JSON=true                     # false → human-readable logs in dev
SENTRY_DSN=                       # set to enable error tracking (empty = off)
WORKER_CONCURRENCY=2              # Celery worker processes
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
STUDENT_UPLOAD_QUOTA=0            # max stored answer audios per student (0 = unlimited)
